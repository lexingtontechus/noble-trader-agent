# mt5-trading-mcp credentials (gitignored). Copy to mt5_mcp.env and fill.
# Source: profile .env already has these values; paste them here.
MT5_ID=your_login_id
MT5_PASSWORD=your_password
MT5_SERVER=PlexyTrade-Server01
MT5_ACCOUNT=your_account_type

