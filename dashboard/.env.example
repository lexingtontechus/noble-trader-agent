# FastAPI backend URL. In dev, Vite proxies /api → this URL.
# In prod, set this to your deployed backend (e.g. https://api.nobletrader.io)
# For single-host deploy (FastAPI serves the SPA bundle), leave this empty.
VITE_API_BASE_URL=

# Auth is handled by the FastAPI backend via session cookies.
# Set these in the BACKEND's .env (not here):
#   HERMES_ADMIN_USERNAME=admin
#   HERMES_ADMIN_PASSWORD=<strong-password>
#   HERMES_SESSION_SECRET=<64-char-random-string>
#   HERMES_AGENT_TOKEN=<long-random-string>     # for programmatic agent access
#
# The SPA doesn't need any auth env vars — the browser sends the session
# cookie automatically (configured via withCredentials: true in api.ts).

