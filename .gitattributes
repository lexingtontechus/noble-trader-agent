# ============================================================
# Line ending normalization — important for Windows + Mac + Linux collaboration
# ============================================================

# Auto-normalize text files on checkout (LF on Mac/Linux, CRLF on Windows)
* text=auto eol=lf

# Force LF for code files (consistent across platforms)
*.py     text eol=lf
*.sql    text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf
*.env    text eol=lf
*.env.example text eol=lf

# Force CRLF for Windows-native scripts
*.ps1    text eol=crlf
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files — never normalize
*.duckdb binary
*.duckdb.wal binary
*.parquet binary
*.png binary
*.jpg binary
*.pdf binary
