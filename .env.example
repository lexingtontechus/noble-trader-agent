# ============================================================
# HERMES TRADING PLATFORM - ENVIRONMENT CONFIGURATION
# ============================================================
#
# ⚠️  SECURITY WARNING: This file contains SENSITIVE information.
# - NEVER commit this file to version control
# - NEVER share this file with anyone
# - Use strong, unique values for all secrets
# - Generate secrets with: python -c "import secrets; print(secrets.token_urlsafe(N))"
#
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
#

# ============================================================
# 🔐 AUTHENTICATION - REQUIRED FOR DASHBOARD
# ============================================================
# These values MUST be set before running 'platform dashboard'
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"

# Session cookie signing secret (64+ characters recommended)
HERMES_SESSION_SECRET=your-64-character-random-session-secret-here

# Dashboard admin credentials (minimum 8 characters for password)
HERMES_ADMIN_USERNAME=your-admin-username
HERMES_ADMIN_PASSWORD=your-strong-password-minimum-16-characters-here

# Agent/bot access token for programmatic API access
HERMES_AGENT_TOKEN=your-64-character-agent-bearer-token-here

# === Secrets backend selection ===
# Which resolver to use for `secret:` prefixed config values
SECRETS_BACKEND=env_file                  # env_file | env | vault | aws_sm
SECRETS_ENV_FILE_PATH=./.env

# === Noble Trader upstream (Redis — real-time heartbeats) ===
# Placeholder URLs — replace with actual values in .env
NOBLE_TRADER_REDIS_URL=redis://<nt-redis-host>:<port>
NOBLE_TRADER_REDIS_CHANNEL=signal.raw.noble_trader
NOBLE_TRADER_REDIS_CONSUMER_GROUP=hermes-l0

# === Noble Trader upstream (Supabase — historical sweeps + regime logs) ===
# Placeholder URL — replace with actual Supabase project URL in .env
SUPABASE_URL=https://<your-project>.supabase.co
# Use the ANON/PUBLISHABLE key (safe for open-source / multi-agent deployments).
# The anon key is subject to Row-Level Security (RLS) policies, which the NT
# operator must configure to allow SELECT on nt_sweep_result + nt_regime_log.
# This is intentionally NOT the service_role key — that would grant full admin
# access to the entire Supabase project, which is unsafe to distribute.
SUPABASE_ANON_KEY=<publishable-anon-key>
SUPABASE_SWEEP_RESULT_TABLE=nt_sweep_result                  # confirmed from NT schema
SUPABASE_REGIME_LOG_TABLE=nt_regime_log                      # confirmed from NT schema

# === Alpaca (stocks + commodities) — paper trading keys ===
# Get paper keys: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=<paper-api-key>
ALPACA_API_SECRET=<paper-api-secret>
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# === Hyperliquid (crypto) — dedicated trading wallet ===
# Generate a NEW wallet for trading; never reuse your main wallet
HYPERLIQUID_WALLET_ADDRESS=<0x-your-dedicated-trading-wallet>
HYPERLIQUID_PRIVATE_KEY=<your-dedicated-wallet-private-key>
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
HYPERLIQUID_VAULT_ADDRESS=                                   # optional, if trading via vault

# === Hermes infrastructure ===
HERMES_DUCKDB_PATH=./data/hermes.duckdb
HERMES_REDIS_URL=redis://localhost:6379/1                     # separate DB number from NT
HERMES_LOG_LEVEL=INFO
HERMES_ENVIRONMENT=development                               # development | staging | production

# === Dashboard / API auth (single-user + agent) ===
# ⚠️  IMPORTANT: These MUST be strong, unique values in production!
# Browser login (session cookie) — set HERMES_ADMIN_PASSWORD to a strong password.
# Generate strong secrets:
#   python -c "import secrets; print('HERMES_SESSION_SECRET=' + secrets.token_urlsafe(48))"
#   python -c "import secrets; print('HERMES_ADMIN_PASSWORD=' + secrets.token_urlsafe(32))"
#   python -c "import secrets; print('HERMES_AGENT_TOKEN=' + secrets.token_urlsafe(64))"
#
# See docs/roadmap.md §14 for the full auth model.
# NOTE: The values above are REQUIRED - there are no default fallbacks!

# Session cookie signing secret (64+ characters required)
# Used to sign session cookies — changing it invalidates all sessions
HERMES_SESSION_SECRET=your-64-character-random-session-secret-here

# Dashboard admin credentials
HERMES_ADMIN_USERNAME=your-admin-username
HERMES_ADMIN_PASSWORD=your-strong-password-minimum-16-characters-here

# Long-lived token for programmatic agent access (sent as Authorization: Bearer <token>)
# Used by the AI agent, scripts, and any non-browser caller of /api/*
HERMES_AGENT_TOKEN=your-64-character-agent-bearer-token-here

# === Notifications (optional) ===
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=

# === Future: forex venue (uncomment when added) ===
# OANDA_API_KEY=
# OANDA_ACCOUNT_ID=

# === Vault / AWS SM (only when SECRETS_BACKEND is vault or aws_sm) ===
# SECRETS_VAULT_ADDR=
# SECRETS_VAULT_TOKEN=
# SECRETS_AWS_REGION=
